# Nosana Model Endpoint
# Get this from deploy.nosana.com after deploying
NOSANA_MODEL_ENDPOINT=https://your-nosana-endpoint.nosana.io/v1

# Agent Server Port
PORT=3000

# Etherscan API Key (free at etherscan.io/apis)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# OpenAI-compatible key — set any value when using Nosana
OPENAI_API_KEY=nosana-key

# ElizaOS log level
ELIZAOS_LOG_LEVEL=info
